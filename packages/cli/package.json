{
  "name": "@zapp/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI for building cross-platform desktop apps with Zapp",
  "main": "dist/zapp-cli.js",
  "bin": {
    "zapp": "dist/zapp-cli.js"
  },
  "exports": {
    ".": "./dist/zapp-cli.js",
    "./config": "./src/config.ts"
  },
  "files": [
    "dist/",
    "native/",
    "src/"
  ],
  "scripts": {
    "build": "bun build ./src/zapp-cli.ts --outfile ./dist/zapp-cli.js --target bun --format esm"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "yargs": "^18.0.0"
  }
}
