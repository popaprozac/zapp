fn app_invoke_rpc(app: App*, method: string, request_payload: string) -> void {
    if method == "" || request_payload == "" {
        return;
    }
    raw {
        const char* json = (const char*)request_payload;
        if (!json) return;

        char requestId[128] = {0};
        char capability[128] = {0};
        char argsPayload[65536] = {0};

        const char* idKey = "\"id\":\"";
        const char* idStart = strstr(json, idKey);
        if (!idStart) return;
        idStart += strlen(idKey);
        const char* idEnd = strchr(idStart, '"');
        if (!idEnd) return;
        size_t idLen = (size_t)(idEnd - idStart);
        if (idLen >= sizeof(requestId)) idLen = sizeof(requestId) - 1;
        memcpy(requestId, idStart, idLen);
        requestId[idLen] = '\0';

        const char* capKey = "\"capability\":\"";
        const char* capStart = strstr(json, capKey);
        if (capStart) {
            capStart += strlen(capKey);
            const char* capEnd = strchr(capStart, '"');
            if (capEnd) {
                size_t capLen = (size_t)(capEnd - capStart);
                if (capLen >= sizeof(capability)) capLen = sizeof(capability) - 1;
                memcpy(capability, capStart, capLen);
                capability[capLen] = '\0';
            }
        }

        const char* argsKey = "\"args\":";
        const char* argsStart = strstr(json, argsKey);
        if (!argsStart) return;
        argsStart += strlen(argsKey);
        while (*argsStart == ' ' || *argsStart == '\n' || *argsStart == '\r' || *argsStart == '\t') {
            argsStart++;
        }
        const char* argsEnd = strstr(argsStart, ",\"meta\"");
        if (!argsEnd) {
            argsEnd = strrchr(argsStart, '}');
        }
        if (!argsEnd || argsEnd <= argsStart) {
            strncpy(argsPayload, "{}", sizeof(argsPayload) - 1);
        } else {
            size_t argsLen = (size_t)(argsEnd - argsStart);
            if (argsLen >= sizeof(argsPayload)) argsLen = sizeof(argsPayload) - 1;
            memcpy(argsPayload, argsStart, argsLen);
            argsPayload[argsLen] = '\0';
        }

        char* errorCode = "";
        char* errorMessage = "";
        char* result = service_invoke_with_policy(
            (App*)app,
            (char*)method,
            argsPayload,
            capability,
            &errorCode,
            &errorMessage
        );

        char response[70000];
        if (errorCode && errorCode[0] != '\0') {
            snprintf(
                response,
                sizeof(response),
                "{\"v\":1,\"id\":\"%s\",\"ok\":false,\"error\":{\"code\":\"%s\",\"message\":\"%s\"}}",
                requestId,
                errorCode,
                errorMessage && errorMessage[0] ? errorMessage : "Service invocation failed"
            );
        } else {
            if (!result || result[0] == '\0') result = "{}";
            snprintf(
                response,
                sizeof(response),
                "{\"v\":1,\"id\":\"%s\",\"ok\":true,\"result\":%s}",
                requestId,
                result
            );
        }

        zapp_dispatch_invoke_result(requestId, response);
    }
}

fn app_handle_frontend_message(app: App*, msg: string) -> void {
    let msg_type: string = "";
    let key: string = "";
    let payload: string = "";
    parse_wire(msg, &msg_type, &key, &payload);

    if msg_type == "invoke" {
        let _ = service_invoke(app, key, payload);
        return;
    }

    if msg_type == "invoke_rpc" {
        app_invoke_rpc(app, key, payload);
        return;
    }

    if msg_type == "emit" {
        app.event.emit(key, payload);
        return;
    }

    if msg_type == "worker" {
        platform_handle_worker_bridge(app, key, payload);
        return;
    }

    if msg_type == "sync" {
        platform_sync_handle_bridge(key, payload);
        return;
    }

    if msg_type == "window" {
        app_handle_window_message(app, key, payload);
        return;
    }

    if msg_type == "app" {
        if key == "configure" {
            app_apply_configure(app, payload);
            return;
        }
        app_handle_app_action(app, key);
        return;
    }
}

// Native entry for ObjC script message handlers.
fn zapp_handle_message(app_ptr: void*, msg_c: string) -> void {
    if app_ptr == NULL || msg_c == NULL {
        return;
    }
    app_handle_frontend_message((App*)app_ptr, msg_c);
}
