@cfg(windows)
fn app_handle_app_action(app: App*, action: string) -> void {
    raw {
    #ifdef _WIN32
        (void)app;
        if (action == NULL) return;
        if (strcmp((const char*)action, "quit") == 0) {
            PostQuitMessage(0);
        }
    #endif
    }
}

